# If you run multiple copies on the same machine, give these unique values.
CODEX_HAPI_HOST=0.0.0.0
CODEX_HAPI_PORT=3113
CODEX_HAPI_BACKEND_TASK_NAME=CodexHapiBackend
CODEX_APP_SERVER_URL=ws://127.0.0.1:8766
CODEX_HAPI_APP_SERVER_TASK_NAME=CodexSharedAppServer

CODEX_HAPI_VOICE_BACKEND=local
CODEX_HAPI_LOCAL_TRANSCRIPTION_PORT=8021
CODEX_HAPI_VOICE_CONTAINER_NAME=codex-hapi-voice-local
CODEX_HAPI_LOCAL_TRANSCRIPTION_URL=http://127.0.0.1:8021/transcribe
CODEX_HAPI_DESKTOP_REFRESH_SCRIPT=./scripts/refresh-desktop-thread.ps1

CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_TOKEN_FILE=./.runtime/cloudflare/tunnel-token.txt

OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

CODEX_HOME=%USERPROFILE%/.codex
